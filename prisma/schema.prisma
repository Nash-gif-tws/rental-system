generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(STAFF)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  STAFF
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Equipment Catalog ───────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  description      String?
  categoryId       String
  category         Category        @relation(fields: [categoryId], references: [id])
  isPackage        Boolean         @default(false)
  isActive         Boolean         @default(true)
  images           String[]
  pricingTiers     PricingTier[]
  units            EquipmentUnit[]
  packageItems     PackageItem[]   @relation("PackageProducts")
  inPackages       PackageItem[]   @relation("PackageContents")
  bookingItems     BookingItem[]
  shopifyProductId String?         @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PackageItem {
  id        String  @id @default(cuid())
  packageId String
  package   Product @relation("PackageProducts", fields: [packageId], references: [id])
  productId String
  product   Product @relation("PackageContents", fields: [productId], references: [id])
  quantity  Int     @default(1)
}

model PricingTier {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  label     String
  days      Int
  price     Float
  isActive  Boolean @default(true)
}

// ─── Physical Inventory ──────────────────────────────────────────────────────

model EquipmentUnit {
  id           String        @id @default(cuid())
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  serialNumber String?       @unique
  size         String?
  condition    Condition     @default(GOOD)
  notes        String?
  isActive     Boolean       @default(true)
  blockouts    Blockout[]
  bookingItems BookingItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum Condition {
  EXCELLENT
  GOOD
  FAIR
  NEEDS_SERVICE
  RETIRED
}

model Blockout {
  id        String        @id @default(cuid())
  unitId    String
  unit      EquipmentUnit @relation(fields: [unitId], references: [id])
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime      @default(now())
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String    @unique
  phone             String?
  dateOfBirth       DateTime?
  shopifyCustomerId String?   @unique
  bookings          Booking[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  id                    String        @id @default(cuid())
  bookingNumber         String        @unique
  customerId            String
  customer              Customer      @relation(fields: [customerId], references: [id])
  status                BookingStatus @default(PENDING)
  startDate             DateTime
  endDate               DateTime
  pickupDate            DateTime?
  returnDate            DateTime?
  subtotal              Float
  discountCode          String?
  discountAmount        Float         @default(0)
  depositAmount         Float         @default(0)
  totalPaid             Float         @default(0)
  notes                 String?
  staffNotes            String?
  height                Float?
  weight                Float?
  skillLevel            SkillLevel?
  bootSize              Float?
  stripePaymentIntentId String?
  stripeDepositIntentId String?
  shopifyOrderId        String?
  waiverSigned          Boolean       @default(false)
  waiverSignedAt        DateTime?
  prepStatus            PrepStatus    @default(NOT_READY)
  readyAt               DateTime?
  readyBy               String?
  pickedUpBy            String?
  items                 BookingItem[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_OUT
  RETURNED
  CANCELLED
  NO_SHOW
}

enum PrepStatus {
  NOT_READY
  READY_FOR_COLLECTION
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model BookingItem {
  id              String         @id @default(cuid())
  bookingId       String
  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  unitId          String?
  unit            EquipmentUnit? @relation(fields: [unitId], references: [id])
  size            String?
  quantity        Int            @default(1)
  unitPrice       Float
  returnCondition Condition?
  returnNotes     String?

  @@index([bookingId])
}
